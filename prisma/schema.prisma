// Prisma schema. To move to Postgres later: change provider to "postgresql"
// and set DATABASE_URL to your Postgres connection string — the models stay the same.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String?  @unique
  passwordHash String?
  isGuest      Boolean  @default(false)
  avatar       String?  // small profile picture as a data URL (base64)

  // ranking + lifetime stats
  rating      Int @default(1000)
  gamesPlayed Int @default(0)
  wins        Int @default(0)
  losses      Int @default(0)
  totalLines  Int @default(0)
  totalScore  Int @default(0)
  bestScore   Int @default(0)

  createdAt    DateTime      @default(now())
  matchPlayers MatchPlayer[]

  // friendships (either side of the relation)
  sentRequests     Friendship[] @relation("FriendRequester")
  receivedRequests Friendship[] @relation("FriendAddressee")
}

// A friend link. status: "pending" (requester -> addressee) or "accepted".
model Friendship {
  id          String   @id @default(cuid())
  requester   User     @relation("FriendRequester", fields: [requesterId], references: [id])
  requesterId String
  addressee   User     @relation("FriendAddressee", fields: [addresseeId], references: [id])
  addresseeId String
  status      String   @default("pending")
  createdAt   DateTime @default(now())

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
}

model Match {
  id      String        @id @default(cuid())
  mode    String        @default("versus")
  endedAt DateTime      @default(now())
  players MatchPlayer[]
}

model MatchPlayer {
  id           String  @id @default(cuid())
  match        Match   @relation(fields: [matchId], references: [id])
  matchId      String
  user         User    @relation(fields: [userId], references: [id])
  userId       String
  score        Int     @default(0)
  lines        Int     @default(0)
  won          Boolean @default(false)
  ratingChange Int     @default(0)

  @@index([userId])
}
