# Copy this file to ".env" for local development:  cp .env.example .env
# (.env is gitignored so your secrets never get committed.)

# Local dev uses SQLite — a single file, zero setup.
DATABASE_URL="file:./dev.db"

# For Postgres (production / Render) it would instead look like:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Secret used to sign login tokens. Use a long random string in production.
JWT_SECRET="dev-secret-change-me-to-something-long-and-random"

PORT=3000
